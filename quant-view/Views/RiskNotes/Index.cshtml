@using SQLitePCL
@model List<RiskNotes.Models.RiskNote>

<h1>Risk Notes</h1>

<a asp-action="Dashboard" class="btn btn-outline-primary mb-3">
    View Dashboard
</a>

<form asp-action="Index" method="GET" class="mb-3">
    <input type="text" name="searchTerm" value="@ViewData["SearchTerm"]"
    class="form-control" placeholder="Search risk notes...">

    <select name="sortBy" class="form-control my-2">
        <option value="">Newest First</option>
        <option value="date_oldest">Oldest First</option>
        <option value="severity">Highest Serverity</option>
    </select>

    <button type="submit" class="btn btn-primary mt-2">Apply</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Clear</a>

</form>

<button id="loadApiData" class="btn btn-outline-secondary mb-3">Load via API</button>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Category</th>
            <th>Description</th>
            <th>Created</th>
            <th>Attachment</th>
            <th>Severity</th>
            <th colspan="3" style="text-align: center;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var note in Model)
        {
            <tr>
                <td>@note.Title</td>
                <td>@note.Category</td>
                <td>@note.Description</td>
                <td>@note.CreatedAt.ToShortDateString()</td>
                <td>@if(note.Attachments != null && note.Attachments.Any())
                    {
                        <a class="badge text-bg-info" asp-action="Details" asp-route-id="@note.Id">📎 @note.Attachments.Count</a>
                    } else
                    {
                        <span class="text-muted">-</span>
                    }
                </td>
                <td>
                    <span class="badge 
                        @(note.Severity == "Critical" ? "text-bg-danger" :
                            note.Severity == "High" ? "text-bg-warning" :
                            note.Severity == "Medium" ? "text-bg-primary" :
                            "text-bg-success")">@note.Severity
                    </span>
                    
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@note.Id" class="btn btn-sm btn-info">Details</a>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@note.Id" class="btn btn-sm btn-warning">Edit</a>
                </td>
                <td>
                    <a asp-action="Delete" asp-route-id="@note.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    @{
        int currentPage = (int)ViewData["CurrentPage"];
        int totalPages = (int)ViewData["TotalPages"];
    }

    <nav>
        <ul class="pagination">
            @for(int i = 1; i <= totalPages; i++)
            {
                <li class="page-itm m-1 @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>

@section Scripts {
    <script>
        document.getElementById("loadApiData").addEventListener("click", async() => {
            const response = await fetch("/api/risknotes");
            const data = await response.json();

            console.log(`API Data: ${data}`);
            alert(`Loaded ${data.length} notes from API`);
        });
    </script>
}


