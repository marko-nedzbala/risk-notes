@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to Risk Note</h1>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <a asp-controller="RiskNotes" asp-action="Create"
                class="btn btn-primary m-3">Create New Risk Note</a>
                <a asp-controller="RiskNotes" asp-action="Index" class="btn btn-primary m-3">View All Notes</a>
                <a asp-controller="RiskNotes" asp-action="Dashboard" class="btn btn-outline-primary m-3">Dashboard</a>
                <a asp-controller="RiskNotes" asp-action="ExportCsv" class="btn btn-outline-success m-3">Export to CSV</a>
                <a asp-controller="RiskNotes" asp-action="ExportExcel" class="btn btn-outline-success m-3">Export to Excel</a>
            </table>
        </div>
    </div>
    

    
</div>


